<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="view_company_form_inherit" model="ir.ui.view">
    <field name="name">res.company.form.inherit</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form" />
    <field name="arch" type="xml">
      <field name="country_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="zip_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="state_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="zip" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="city_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="city" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="street" position="before">
        <field name="is_show_company_registry" invisible="1" />
        <field name="is_address_details" invisible="1" />
        <field
          id="country_id"
          name="country_id"
          placeholder="Country"
          class="o_address_country"
          options="{'no_open': True, 'no_create': True}"
        />
        <div id="house_number" name="house_number" class="o_row oe_edit_only">
          <field
            name="house_number"
            invisible="is_address_details == False"
            placeholder="No."
            class="o_address_house_number"
          />
          <field
            name="village_number"
            invisible="is_address_details == False"
            placeholder="Moo"
            class="o_address_village_number"
          />
          <field
            name="village"
            invisible="is_address_details == False"
            placeholder="Village"
            class="o_address_village"
          />
        </div>
        <div id="building" name="building" class="o_row oe_edit_only">
          <field
            name="building"
            invisible="is_address_details == False"
            placeholder="Building"
            class="o_address_building"
          />
          <field
            name="floor"
            invisible="is_address_details == False"
            placeholder="Floor"
            class="o_address_floor"
          />
          <field
            name="room_number"
            invisible="is_address_details == False"
            placeholder="Room No."
            class="o_address_room_number"
          />
        </div>
        <div id="alley" name="alley" class="o_row oe_edit_only">
          <field
            name="alley"
            invisible="is_address_details == False"
            placeholder="Alley"
            class="o_address_alley"
          />
          <field
            name="sub_alley"
            invisible="is_address_details == False"
            placeholder="Sub Alley"
            class="o_address_sub_alley"
          />
        </div>
      </field>

      <field name="street2" position="attributes">
        <attribute name="invisible">is_address_details == True</attribute>
      </field>

      <field name="street2" position="after">
        <div id="state" name="state" class="o_row oe_edit_only">
          <field
            id="state"
            name="state_id"
            placeholder="State"
            context="{'country_id': country_id, 'zip': zip}"
            options="{'no_open': True, 'no_create': True}"
          />
        </div>
        <div id="city" name="city" class="o_row oe_edit_only">
          <field
            id="city"
            name='city_id'
            placeholder="City"
            string="City"
            context="{'default_country_id': country_id, 'default_name': city, 'default_zipcode': zip, 'default_state_id': state_id}"
            options="{'no_create': True}"
          />
          <field
            id="subdistrict"
            name='subdistrict_id'
            placeholder="Subdistrict"
            string="Subdistrict"
            context="{'default_city_id': city_id, 'default_state_id': state_id}"
            options="{'no_create': True}"
          />
        </div>
        <div id="zip" name="zip" class="o_row oe_edit_only">
          <field
            id="zip"
            name="zip_id"
            placeholder="Zip"
            domain="[('subdistrict_ids', 'in', subdistrict_id)]"
            options="{'no_create': True}"
          />
        </div>
      </field>

      <field name="company_registry" position="attributes">
        <attribute name="invisible">is_show_company_registry == False</attribute>
      </field>
    </field>
  </record>
</odoo>
