<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="city_zip_tree_inherit" model="ir.ui.view">
    <field name="name">res.city.zip.tree</field>
    <field name="model">res.city.zip</field>
    <field name="inherit_id" ref="base_location.city_zip_tree" />
    <field name="arch" type="xml">
      <xpath expr="//list/field[@name='city_id']" position="attributes">
        <attribute name="column_invisible">1</attribute>
      </xpath>
      <field name="city_id" position="after">
        <field name="city_ids" widget="many2many_tags" />
        <field name="subdistrict_ids" />
      </field>
    </field>
  </record>

  <record id="city_zip_form_inherit" model="ir.ui.view">
    <field name="name">res.city.zip.form.inherit</field>
    <field name="model">res.city.zip</field>
    <field name="priority">88</field>
    <field name="inherit_id" ref="base_location.city_zip_form" />
    <field name="arch" type="xml">
      <xpath expr="//form" position="attributes">
        <attribute name="string">Zipcode</attribute>
      </xpath>

      <xpath expr="//form/group" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>

      <xpath expr="//form" position="inside">
        <sheet>
          <group id="city_zip" name="city_zip" col="4">
            <field name="name" />
            <field name="country_id" required="1" />
            <field name="city_ids" widget="many2many_tags" />
            <field name="subdistrict_ids" widget="many2many_tags" />
          </group>
        </sheet>
      </xpath>
    </field>
  </record>

  <record id="view_city_zip_filter_inherit" model="ir.ui.view">
    <field name="model">res.city.zip</field>
    <field name="inherit_id" ref="base_location.view_city_zip_filter" />
    <field name="arch" type="xml">
      <field name="city_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>

      <field name="city_id" position="after">
        <field name="subdistrict_ids" />
      </field>
    </field>
  </record>

  <record id="base_location.action_zip_tree" model="ir.actions.act_window">
    <field name="name">Zipcode</field>
  </record>
</odoo>
