<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="view_tax_form" model="ir.ui.view">
    <field name="name">account.tax.form.inherit.hide.withholding_sequence</field>
    <field name="model">account.tax</field>
    <field name="inherit_id" ref="l10n_account_withholding_tax.view_tax_form" />
    <field name="arch" type="xml">
      <field name="withholding_sequence_id" position="attributes">
        <attribute name="invisible">1</attribute>
      </field>
      <field name="is_base_affected" position="after">
        <field
          name="type_income"
          invisible="not is_withholding_tax_on_payment"
          required="is_withholding_tax_on_payment"
        />
      </field>
    </field>
  </record>
</odoo>
